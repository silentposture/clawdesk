# ClawDesk Windows direct-download Beta release environment template.
# Do not commit real values. This file documents required variable names only.
#
# First release target:
# - Windows 11 x64 direct-download NSIS installer
# - Lemon Squeezy license flow
# - Production Gateway
# - Authenticode / Windows certificate signing
# - No Microsoft Store gate
# - No SSO gate
CLAWDESK_RELEASE_CHANNEL=beta-direct

# Required for Windows direct-download Beta: Production Gateway adapter.
CLAWDESK_GATEWAY_BASE_URL=
# Optional when the events endpoint is not <base-url>/events.
CLAWDESK_GATEWAY_WS_URL=

# Required for Windows direct-download Beta: production backend adapter selection.
# Default local simulator mode is mock.
CLAWDESK_BACKEND_ADAPTER_MODE=production

# Required for Windows direct-download Beta: Lemon Squeezy payment and license provider.
# Desktop builds must never store Lemon API secrets or customer payment data.
LEMON_SQUEEZY_WEBHOOK_SECRET=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_PRODUCT_ID=
LEMON_SQUEEZY_VARIANT_ID_PRO_YEARLY=
LEMON_SQUEEZY_VARIANT_ID_LIFETIME=
# Optional server-side API key for backend-only Lemon API calls. Do not expose to the desktop app.
LEMON_SQUEEZY_API_KEY=

# Required for Windows direct-download Beta: public support contact. Set at least one.
CLAWDESK_SUPPORT_EMAIL=alison.ai.tech.studio@gmail.com
CLAWDESK_SUPPORT_URL=

# Required for Windows direct-download Beta: Windows code signing.
# Choose exactly ONE signing method below. Do not configure multiple methods at once.
#
# Method A: PFX path flow. Keep the certificate outside git; never commit the password.
WINDOWS_SIGNING_CERTIFICATE=
WINDOWS_SIGNING_CERTIFICATE_PASSWORD=
#
# Method B: Windows certificate store flow. Use this instead of PFX when the cert is installed in CurrentUser/My.
WINDOWS_SIGNING_CERTIFICATE_SUBJECT=
WINDOWS_SIGNING_TIMESTAMP_URL=http://timestamp.digicert.com

# Method C: Optional / future CI signing: Microsoft Trusted Signing / Azure Artifact Signing.
# If this method is used, local sign:win-installer will intentionally stop; signing should run in CI/Azure.
AZURE_TRUSTED_SIGNING_ACCOUNT_NAME=
AZURE_TRUSTED_SIGNING_CERTIFICATE_PROFILE_NAME=
AZURE_TRUSTED_SIGNING_ENDPOINT=

# Optional / enterprise SSO. Not required for the first Windows direct-download Beta.
CLAWDESK_SSO_ISSUER_URL=
CLAWDESK_SSO_CLIENT_ID=

# Optional / future Store or updater metadata. Do not block direct-download Beta on these.
CLAWDESK_UPDATE_FEED_URL=
CLAWDESK_MICROSOFT_STORE_PUBLISHER=

# Optional / future macOS signing / notarization.
APPLE_DEVELOPER_IDENTITY=
APPLE_ID=
APPLE_TEAM_ID=
APPLE_APP_SPECIFIC_PASSWORD=
