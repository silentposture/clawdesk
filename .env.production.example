# ClawDesk strict production release environment template.
# Do not commit real values. This file documents required variable names only.

CLAWDESK_RELEASE_CHANNEL=production

# Production Gateway adapter
CLAWDESK_GATEWAY_BASE_URL=
# Optional when the events endpoint is not <base-url>/events.
CLAWDESK_GATEWAY_WS_URL=

# Production backend adapter selection. Default local simulator mode is mock.
CLAWDESK_BACKEND_ADAPTER_MODE=production

# Paddle Merchant of Record
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRODUCT_ID=
PADDLE_PRICE_ID_PRO_MONTHLY=
PADDLE_PRICE_ID_PRO_YEARLY=
PADDLE_PRICE_ID_LIFETIME=
PADDLE_PRICE_ID_TEAM=

# Lemon Squeezy direct-download Beta
LEMON_SQUEEZY_WEBHOOK_SECRET=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_PRODUCT_ID=
LEMON_SQUEEZY_VARIANT_ID_PRO_YEARLY=
LEMON_SQUEEZY_VARIANT_ID_LIFETIME=

# Keygen licensing
KEYGEN_ACCOUNT_ID=
KEYGEN_PRODUCT_ID=
KEYGEN_POLICY_ID=
KEYGEN_SIGNING_PUBLIC_KEY=

# SSO / account identity provider
CLAWDESK_SSO_ISSUER_URL=
CLAWDESK_SSO_CLIENT_ID=

# Windows code signing
WINDOWS_SIGNING_CERTIFICATE=
WINDOWS_SIGNING_CERTIFICATE_PASSWORD=

# Microsoft Trusted Signing / Azure Artifact Signing
AZURE_TRUSTED_SIGNING_ACCOUNT_NAME=
AZURE_TRUSTED_SIGNING_CERTIFICATE_PROFILE_NAME=
AZURE_TRUSTED_SIGNING_ENDPOINT=

# Updater / Store metadata
CLAWDESK_UPDATE_FEED_URL=
CLAWDESK_MICROSOFT_STORE_PUBLISHER=

# macOS signing / notarization
APPLE_DEVELOPER_IDENTITY=
APPLE_ID=
APPLE_TEAM_ID=
APPLE_APP_SPECIFIC_PASSWORD=
