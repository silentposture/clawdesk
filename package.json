{
  "name": "clawdesk-desktop-mvp",
  "version": "0.1.0",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "npm run legal:manifest && npm run legal:notices && tsc && vite build",
    "icons": "node scripts/generate-icons.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "test": "npm run legal:manifest && vitest run",
    "test:watch": "vitest",
    "preflight": "node scripts/preflight.mjs",
    "release:guard": "node scripts/release-guard.mjs",
    "release:guard:strict": "node scripts/release-guard.mjs --strict-production --require-signing",
    "release:guard:beta": "node scripts/release-guard.mjs --beta-direct --require-signing --require-artifacts",
    "cert:windows:check": "node scripts/release-guard.mjs --beta-direct --require-signing --require-artifacts",
    "beta:env:doctor": "node scripts/beta-direct-env-doctor.mjs",
    "beta:readiness": "node scripts/beta-readiness-report.mjs",
    "beta:readiness:check": "node scripts/beta-readiness-report.mjs --fail-on-blocked",
    "beta:handoff:prepare": "node scripts/prepare-beta-handoff.mjs",
    "gateway:doctor": "node scripts/production-gateway-doctor.mjs",
    "legal:manifest": "node scripts/generate-legal-consent.mjs",
    "legal:manifest:check": "node scripts/generate-legal-consent.mjs --check",
    "legal:notices": "node scripts/generate-third-party-notices.mjs",
    "legal:notices:check": "node scripts/generate-third-party-notices.mjs --check",
    "release:metadata:win": "node scripts/generate-windows-release-metadata.mjs",
    "release:metadata:win:check": "node scripts/generate-windows-release-metadata.mjs --check",
    "i18n:audit": "node scripts/audit-i18n-literals.mjs",
    "i18n:audit:strict": "node scripts/audit-i18n-literals.mjs --strict",
    "policy:hidden-window": "node scripts/enforce-hidden-window-policy.mjs",
    "policy:branch-protection:check": "node scripts/verify-branch-protection-readiness.mjs",
    "audit:tasks:hidden": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/audit-scheduled-tasks.ps1",
    "audit:tasks:hidden:allstudio": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"$env:CLAWDESK_TASK_AUDIT_PATTERNS='^Studio_,^OpenClaw,^NaviaWorks,^LumiCore'; & ./scripts/audit-scheduled-tasks.ps1\"",
    "sbom": "node scripts/generate-sbom.mjs",
    "sbom:check": "node scripts/generate-sbom.mjs --check",
    "release:configs:check": "node scripts/validate-release-configs.mjs",
    "verify:mvp": "node scripts/verify-mvp.mjs",
    "verify:backend": "node scripts/verify-backend.mjs",
    "verify:backend:sim": "node scripts/verify-backend-sim.mjs",
    "verify:production-gateway:sim": "node scripts/verify-production-gateway-sim.mjs",
    "verify:reports:check": "node scripts/validate-verify-reports.mjs",
    "verify:production-gateway:compose": "node scripts/verify-production-gateway-compose.mjs",
    "verify:lemon:production": "node scripts/verify-lemon-production.mjs",
    "smoke:gui": "node scripts/smoke-gui.mjs",
    "smoke:gui:prod": "node scripts/smoke-gui.mjs --app-server=preview",
    "verify:ui:visual": "node scripts/ui-visual-regression.mjs",
    "smoke:win-app": "node scripts/smoke-win-app.mjs",
    "smoke:win-installer": "node scripts/smoke-win-installer.mjs",
    "smoke:store-installer:win": "node scripts/smoke-store-installer-win.mjs",
    "smoke:mac-dmg": "node scripts/smoke-mac-dmg.mjs",
    "sign:win-installer": "node scripts/sign-win-installer.mjs",
    "sign:win:doctor": "node scripts/windows-signing-doctor.mjs",
    "smoke:gui:attach": "node scripts/smoke-gui.mjs --connect-only",
    "qa:cycle": "node scripts/qa-loop.mjs",
    "qa:once": "node scripts/qa-loop.mjs --cycles 1",
    "qa:quick": "node scripts/qa-loop.mjs --quick",
    "qa:burn-in": "node scripts/qa-loop.mjs --cycles 3 --continue-on-failure",
    "qa:release": "node scripts/qa-loop.mjs --production-smoke",
    "qa:release:burn-in": "node scripts/qa-loop.mjs --production-smoke --cycles 2 --continue-on-failure",
    "qa:release:app": "node scripts/qa-loop.mjs --production-smoke --tauri-app-smoke",
    "qa:release:win": "node scripts/qa-loop.mjs --production-smoke --tauri-app-smoke --windows-installer-smoke",
    "qa:full:win": "node scripts/qa-win-one-shot.mjs",
    "qa:full:win:sign": "node scripts/qa-win-one-shot.mjs --require-signature",
    "qa:beta-direct:win": "npm run release:guard:beta && npm run smoke:gui:prod && npm run smoke:win-app -- --no-build && npm run smoke:win-installer -- --no-build",
    "qa:store:win": "node scripts/qa-loop.mjs --production-smoke --store-installer-smoke",
    "qa:release:mac": "node scripts/qa-loop.mjs --production-smoke --mac-dmg-smoke",
    "release:auto:beta:win": "node scripts/auto-beta-release-win.mjs",
    "lemon:onboarding:prepare": "node scripts/prepare-lemon-onboarding.mjs",
    "website:prepare": "node scripts/prepare-website-release.mjs",
    "qa:quick-attach": "node scripts/qa-loop.mjs --quick --smoke-connect-only",
    "qa:attach": "node scripts/qa-loop.mjs --cycles 1 --smoke-connect-only --skip-unit --skip-build --skip-verify-mvp --skip-verify-backend --skip-verify-backend-sim --skip-cargo-test",
    "qa:attach:quick": "npm run qa:attach",
    "gateway": "node sidecars/mock-gateway/server.mjs",
    "gateway:deploy:prepare": "node scripts/prepare-gateway-deploy-package.mjs",
    "gateway:public:doctor": "node scripts/gateway-public-doctor.mjs",
    "tauri": "tauri",
    "tauri:dev:win": "npm run icons && tauri dev",
    "tauri:build:win": "node scripts/build-windows.mjs",
    "tauri:build:store:win": "node scripts/build-windows.mjs --store",
    "tauri:build:prod:win": "node scripts/build-windows.mjs --production",
    "tauri:build:mac": "node scripts/build-macos.mjs",
    "tauri:app-smoke": "npm run smoke:win-app",
    "deploy:mock": "docker compose -f docker-compose.mock-gateway.yml up -d",
    "deploy:mock:down": "docker compose -f docker-compose.mock-gateway.yml down",
    "deploy:mock:logs": "docker compose -f docker-compose.mock-gateway.yml logs -f mock-gateway",
    "deploy:backend-sim": "docker compose -f docker-compose.backend-sim.yml up -d",
    "deploy:backend-sim:down": "docker compose -f docker-compose.backend-sim.yml down",
    "deploy:backend-sim:logs": "docker compose -f docker-compose.backend-sim.yml logs -f backend-auth",
    "deploy:mock:full": "node scripts/deploy-mock-full.mjs up",
    "deploy:mock:full:down": "node scripts/deploy-mock-full.mjs down",
    "deploy:mock:full:logs": "node scripts/deploy-mock-full.mjs logs",
    "deploy:mock:full:check": "node scripts/deploy-mock-full.mjs check",
    "deploy:mock:full:docker-only": "docker compose -f docker-compose.mock-gateway.full.yml up -d",
    "deploy:full:stack": "node scripts/deploy-full-stack.mjs up",
    "deploy:full:stack:down": "node scripts/deploy-full-stack.mjs down",
    "deploy:full:stack:logs": "node scripts/deploy-full-stack.mjs logs",
    "deploy:full:stack:check": "node scripts/deploy-full-stack.mjs check",
    "deploy:full:stack:docker-only": "docker compose -f docker-compose.mock-gateway.full.yml -f docker-compose.backend-sim.yml up -d",
    "stack:local": "node scripts/run-local-stack.mjs",
    "stack:local:check": "node scripts/run-local-stack.mjs --check",
    "verify:mock-stack": "node scripts/verify-backend.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.2.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.2.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.59.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.6"
  }
}
